# Copy to .env for local Compose overrides (optional; Compose has matching defaults).
POSTGRES_USER=flight
POSTGRES_PASSWORD=flight
POSTGRES_DB=flight_tracker

# App / migrate (Compose sets these for the containers; use host-local values for go run).
DATABASE_DRIVER=postgres
DATABASE_URL=postgres://flight:flight@localhost:5432/flight_tracker?sslmode=disable
MIGRATIONS_PATH=migrations/postgres
