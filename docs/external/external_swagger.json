{
    "swagger": "2.0",
    "info": {
        "description": "REST API for flight data ingest, job status, and route performance.",
        "title": "flight-tracker API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/routes/outlook": {
            "get": {
                "description": "On-time, delay, cancellation, and diversion probabilities for a carrier/route/day/departure-time window, based on the trailing analysis period. Day of week uses 1=Monday through 7=Sunday. dep_time is local departure time as HHmm (e.g. 0700). dep_time_window_minutes defaults to 30 (max 120).",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "routes",
                    "external"
                ],
                "summary": "Route booking outlook",
                "parameters": [
                    {
                        "maxLength": 3,
                        "minLength": 3,
                        "type": "string",
                        "description": "Origin airport IATA code",
                        "name": "origin",
                        "in": "query",
                        "required": true
                    },
                    {
                        "maxLength": 3,
                        "minLength": 3,
                        "type": "string",
                        "description": "Destination airport IATA code",
                        "name": "dest",
                        "in": "query",
                        "required": true
                    },
                    {
                        "maxLength": 2,
                        "minLength": 2,
                        "type": "string",
                        "description": "Marketing carrier code",
                        "name": "carrier",
                        "in": "query",
                        "required": true
                    },
                    {
                        "maximum": 7,
                        "minimum": 1,
                        "type": "integer",
                        "description": "Day of week (1=Mon … 7=Sun)",
                        "name": "day_of_week",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Scheduled departure time (HHmm)",
                        "name": "dep_time",
                        "in": "query",
                        "required": true
                    },
                    {
                        "maximum": 120,
                        "minimum": 1,
                        "type": "integer",
                        "description": "Minutes around dep_time to include (default 30, max 120)",
                        "name": "dep_time_window_minutes",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.RouteOutlook"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/v1/routes/stats": {
            "get": {
                "description": "Aggregated on-time, delay, cancellation, and diversion stats for a route over a date range (max 366 days). Origin and dest are 3-letter airport codes. Days of week use 1=Monday through 7=Sunday.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "routes",
                    "external"
                ],
                "summary": "Route performance stats",
                "parameters": [
                    {
                        "maxLength": 3,
                        "minLength": 3,
                        "type": "string",
                        "description": "Origin airport IATA code",
                        "name": "origin",
                        "in": "query",
                        "required": true
                    },
                    {
                        "maxLength": 3,
                        "minLength": 3,
                        "type": "string",
                        "description": "Destination airport IATA code",
                        "name": "dest",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "format": "date",
                        "description": "Range start (YYYY-MM-DD)",
                        "name": "start_date",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "format": "date",
                        "description": "Range end (YYYY-MM-DD), on or after start_date",
                        "name": "end_date",
                        "in": "query",
                        "required": true
                    },
                    {
                        "maxLength": 2,
                        "minLength": 2,
                        "type": "string",
                        "description": "Marketing carrier code (required if flight_number is set)",
                        "name": "carrier",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Flight number (requires carrier)",
                        "name": "flight_number",
                        "in": "query"
                    },
                    {
                        "maximum": 7,
                        "minimum": 1,
                        "type": "array",
                        "items": {
                            "type": "integer"
                        },
                        "collectionFormat": "multi",
                        "description": "Filter to these weekdays (1=Mon … 7=Sun)",
                        "name": "days_of_week",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/model.RouteStats"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "model.AirportCount": {
            "type": "object",
            "properties": {
                "airport": {
                    "type": "string"
                },
                "count": {
                    "type": "integer"
                }
            }
        },
        "model.CancellationCodeCount": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "count": {
                    "type": "integer"
                }
            }
        },
        "model.DelayCausesAvgMinutes": {
            "type": "object",
            "properties": {
                "carrier": {
                    "type": "number"
                },
                "late_aircraft": {
                    "type": "number"
                },
                "nas": {
                    "type": "number"
                },
                "security": {
                    "type": "number"
                },
                "weather": {
                    "type": "number"
                }
            }
        },
        "model.RouteOutlook": {
            "type": "object",
            "properties": {
                "analysis_end": {
                    "type": "string"
                },
                "analysis_start": {
                    "type": "string"
                },
                "cancellation_probability": {
                    "type": "number"
                },
                "carrier": {
                    "type": "string"
                },
                "day_of_week": {
                    "type": "integer"
                },
                "delay_probability": {
                    "type": "number"
                },
                "dep_time": {
                    "type": "string"
                },
                "dep_time_window_minutes": {
                    "type": "integer"
                },
                "dest": {
                    "type": "string"
                },
                "diversion_probability": {
                    "type": "number"
                },
                "insufficient_sample": {
                    "type": "boolean"
                },
                "likely_arrival_delay_minutes": {
                    "type": "number"
                },
                "likely_arrival_delay_when_delayed": {
                    "type": "number"
                },
                "likely_departure_delay_minutes": {
                    "type": "number"
                },
                "median_arrival_delay_minutes": {
                    "type": "number"
                },
                "median_arrival_delay_when_delayed": {
                    "type": "number"
                },
                "on_time_probability": {
                    "type": "number"
                },
                "origin": {
                    "type": "string"
                },
                "sample_size": {
                    "type": "integer"
                }
            }
        },
        "model.RouteStats": {
            "type": "object",
            "properties": {
                "avg_arrival_delay_minutes": {
                    "type": "number"
                },
                "avg_arrival_delay_when_delayed": {
                    "type": "number"
                },
                "avg_departure_delay_minutes": {
                    "type": "number"
                },
                "avg_departure_delay_when_delayed": {
                    "type": "number"
                },
                "cancellation_codes": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.CancellationCodeCount"
                    }
                },
                "cancellation_rate": {
                    "type": "number"
                },
                "cancelled": {
                    "type": "integer"
                },
                "delay_causes_avg_minutes": {
                    "$ref": "#/definitions/model.DelayCausesAvgMinutes"
                },
                "delay_rate": {
                    "type": "number"
                },
                "delayed": {
                    "type": "integer"
                },
                "dest": {
                    "type": "string"
                },
                "diversion_airports": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/model.AirportCount"
                    }
                },
                "diversion_rate": {
                    "type": "number"
                },
                "diverted": {
                    "type": "integer"
                },
                "end_date": {
                    "type": "string"
                },
                "filters": {
                    "$ref": "#/definitions/model.RouteStatsFilters"
                },
                "flights": {
                    "type": "integer"
                },
                "median_arrival_delay_minutes": {
                    "type": "number"
                },
                "median_arrival_delay_when_delayed": {
                    "type": "number"
                },
                "on_time": {
                    "type": "integer"
                },
                "on_time_rate": {
                    "type": "number"
                },
                "origin": {
                    "type": "string"
                },
                "start_date": {
                    "type": "string"
                }
            }
        },
        "model.RouteStatsFilters": {
            "type": "object",
            "properties": {
                "carrier": {
                    "type": "string"
                },
                "days_of_week": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    }
                },
                "flight_number": {
                    "type": "string"
                }
            }
        }
    }
}